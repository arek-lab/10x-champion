---
import Layout from "@/layouts/Layout.astro";

interface Props {
  roomNumber: string;
  guestName: string;
  checkOutDate: string;
}

const { roomNumber, guestName, checkOutDate } = Astro.props;

const formattedCheckOut = new Date(checkOutDate + "T00:00:00Z").toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});
---

<Layout title={`Room ${roomNumber} — Guest Panel`}>
  <div class="bg-background min-h-screen">
    <header class="border-border bg-card border-b px-6 py-4">
      <div class="mx-auto flex max-w-2xl items-center justify-between">
        <div>
          <span class="text-foreground text-2xl font-bold">Room {roomNumber}</span>
        </div>
        <div class="text-muted-foreground text-right text-sm">
          <div class="text-foreground font-medium">{guestName}</div>
          <div>Check-out: {formattedCheckOut}</div>
        </div>
      </div>
    </header>
    <main class="mx-auto max-w-2xl px-6 py-8">
      <slot />
    </main>
  </div>
</Layout>
