---
import Layout from "@/layouts/Layout.astro";

interface Props {
  roomNumber: string;
  guestName: string;
  checkOutDate: string;
}

const { roomNumber, guestName, checkOutDate } = Astro.props;

const firstName = guestName.split(" ")[0];

const formattedCheckOut = new Date(checkOutDate + "T00:00:00Z").toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});
---

<Layout title={`Room ${roomNumber} — Guest Panel`}>
  <div class="bg-background min-h-screen">
    <header class="border-border bg-background sticky top-0 z-10 border-b px-6 py-3">
      <div class="mx-auto flex max-w-2xl items-center justify-between">
        <div class="flex items-baseline gap-2">
          <span class="text-foreground font-serif text-lg">{firstName}</span>
          <span class="text-muted-foreground text-sm">Room {roomNumber}</span>
        </div>
        <div class="text-muted-foreground text-right text-xs">
          Check-out: {formattedCheckOut}
        </div>
      </div>
    </header>
    <main class="mx-auto max-w-2xl px-4 py-6">
      <slot />
    </main>
  </div>
</Layout>
