---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";

interface Props {
  title: string;
}

const { title } = Astro.props;

const supabase = createClient(Astro.request.headers, Astro.cookies);
let pendingCount = 0;
if (supabase) {
  const { count } = await supabase.from("orders").select("*", { count: "exact", head: true }).eq("status", "pending");
  pendingCount = count ?? 0;
}
---

<Layout title={title}>
  <div class="bg-cosmic min-h-screen">
    <nav
      class="flex items-center justify-between border-b border-white/10 bg-black/20 px-6 py-4 backdrop-blur-sm print:hidden"
    >
      <span class="text-lg font-bold text-white">RoomPilot</span>
      <div class="flex items-center gap-4">
        <a href="/dashboard/generate-token" class="text-sm text-blue-200 transition-colors hover:text-white">
          Generate Token
        </a>
        <a href="/dashboard" class="flex items-center gap-1.5 text-sm text-blue-200 transition-colors hover:text-white">
          Orders
          <span
            id="pending-badge"
            class:list={[
              "flex h-5 min-w-5 items-center justify-center rounded-full bg-red-500 px-1.5 text-xs font-bold text-white",
              { hidden: pendingCount === 0 },
            ]}
          >
            {pendingCount}
          </span>
        </a>
        <form method="POST" action="/api/auth/signout">
          <button
            type="submit"
            class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm text-white transition-colors hover:bg-white/20"
          >
            Sign Out
          </button>
        </form>
      </div>
    </nav>
    <main>
      <slot />
    </main>
  </div>
  <script>
    window.addEventListener("pending-count-update", (e) => {
      const badge = document.getElementById("pending-badge");
      if (!badge) return;
      const count = (e as CustomEvent<number>).detail;
      badge.textContent = String(count);
      badge.classList.toggle("hidden", count === 0);
    });
  </script>
</Layout>
