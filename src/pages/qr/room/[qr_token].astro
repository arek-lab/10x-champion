---
export const prerender = false;
import { GUEST_SESSION_SECRET } from "astro:env/server";
import { createServiceRoleClient } from "@/lib/supabase";
import { processQrAuth } from "@/lib/qr-auth";

if (Astro.locals.guestToken) {
  return Astro.redirect("/guest/panel", 302);
}

const { qr_token } = Astro.params;
if (!qr_token) {
  return Astro.redirect("/guest/error?reason=invalid", 302);
}

if (!GUEST_SESSION_SECRET) {
  return Astro.redirect("/guest/error?reason=invalid", 302);
}

const supabase = createServiceRoleClient();
if (!supabase) {
  return Astro.redirect("/guest/error?reason=invalid", 302);
}

const result = await processQrAuth({
  qrToken: qr_token,
  pendingCookieValue: Astro.cookies.get("pending_guest")?.value,
  secret: new TextEncoder().encode(GUEST_SESSION_SECRET),
  supabase,
  today: new Date().toISOString().slice(0, 10),
});

if (result.type === "error") {
  return Astro.redirect("/guest/error?reason=" + result.reason, 302);
}

Astro.cookies.set("guest_session", result.sessionJwt, {
  httpOnly: true,
  secure: true,
  sameSite: "lax",
  path: "/",
  expires: result.sessionExpiry,
});

Astro.cookies.set("pending_guest", "", {
  httpOnly: true,
  secure: true,
  sameSite: "lax",
  path: "/qr",
  maxAge: 0,
});

return Astro.redirect("/guest/panel", 302);
---
