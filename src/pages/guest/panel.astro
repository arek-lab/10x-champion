---
export const prerender = false;
import GuestLayout from "@/layouts/GuestLayout.astro";
import { createServiceRoleClient } from "@/lib/supabase";
import AddonList from "@/components/guest/AddonList";
import ConciergeWidget from "@/components/guest/ConciergeWidget";
import { ServiceCard } from "@/components/guest/ServiceCard";

if (!Astro.locals.guestToken) {
  return Astro.redirect("/guest/error?reason=invalid", 302);
}

const { tokenId, packageId } = Astro.locals.guestToken;

const supabase = createServiceRoleClient();
if (!supabase) {
  return Astro.redirect("/guest/error?reason=invalid", 302);
}

const { data: guestTokenRow, error: tokenError } = await supabase
  .from("guest_tokens")
  .select("id, guest_name, room_number, check_out_date")
  .eq("id", tokenId)
  .maybeSingle();

if (tokenError || !guestTokenRow) {
  return Astro.redirect("/guest/error?reason=invalid", 302);
}

const today = new Date().toISOString().slice(0, 10);
if (guestTokenRow.check_out_date < today) {
  return Astro.redirect("/guest/error?reason=expired", 302);
}

const { data: packageServicesRows, error: pkgError } = await supabase
  .from("package_services")
  .select("inclusion_type, service_id, services(id, name, description, category, active, price_pln, image_url)")
  .eq("package_id", packageId)
  .eq("services.active", true);

if (pkgError) {
  return Astro.redirect("/guest/error?reason=invalid", 302);
}

const rows = packageServicesRows;

const included = rows.filter((r) => r.inclusion_type === "included").map((r) => r.services);

const addons = rows.filter((r) => r.inclusion_type === "addon").map((r) => r.services);

const { data: ordersRows } = await supabase
  .from("orders")
  .select("id, service_id, status, created_at")
  .eq("guest_token_id", tokenId)
  .order("created_at", { ascending: false });

const { guest_name, room_number, check_out_date } = guestTokenRow;
---

<GuestLayout roomNumber={room_number} guestName={guest_name} checkOutDate={check_out_date}>
  <section class="mb-8">
    <h2 class="text-foreground mb-4 font-serif text-xl">Included in your package</h2>
    {
      included.length === 0 ? (
        <p class="text-muted-foreground text-sm">No included services found for your package.</p>
      ) : (
        <div class="grid grid-cols-1 gap-4 min-[360px]:grid-cols-2">
          {included.map((service) => (
            <ServiceCard
              variant="included"
              id={service.id}
              name={service.name}
              description={service.description}
              category={service.category}
              imageUrl={service.image_url}
            />
          ))}
        </div>
      )
    }
  </section>

  <section>
    <h2 class="text-foreground mt-8 mb-4 font-serif text-xl">Available add-ons</h2>
    <AddonList client:load addons={addons} initialOrders={ordersRows ?? []} />
  </section>

  <ConciergeWidget client:load />
</GuestLayout>
