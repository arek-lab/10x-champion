---
import StaffLayout from "@/layouts/StaffLayout.astro";
import { createClient } from "@/lib/supabase";

const { user } = Astro.locals;

const supabase = createClient(Astro.request.headers, Astro.cookies);
let pendingCount = 0;
if (supabase) {
  const { count } = await supabase.from("orders").select("*", { count: "exact", head: true }).eq("status", "pending");
  pendingCount = count ?? 0;
}
---

<StaffLayout title="Dashboard">
  <div class="flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center gap-6 p-4">
    <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-center text-white backdrop-blur-xl">
      <h1 class="mb-4 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
        Dashboard
      </h1>
      <p class="text-blue-100/80">
        Welcome, <span class="font-semibold text-white">{user?.email}</span>
      </p>
      <p class="mt-2 text-sm text-blue-100/50">This page is only for authenticated users.</p>
    </div>
    <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-center text-white backdrop-blur-xl">
      <h2 class="mb-3 text-lg font-semibold text-blue-100/80">Pending Orders</h2>
      <p class="text-5xl font-bold text-white">{pendingCount}</p>
      <p class="mt-2 text-sm text-blue-100/50">orders awaiting fulfillment</p>
    </div>
  </div>
</StaffLayout>
