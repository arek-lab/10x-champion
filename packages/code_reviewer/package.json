{
  "name": "@room-pilot/code-reviewer",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "AI-powered code reviewer (AI SDK + OpenRouter).",
  "main": "dist/index.js",
  "bin": {
    "code-reviewer": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/cli.ts",
    "start": "tsx --env-file-if-exists=.env src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "ai": "^6.0.208",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
